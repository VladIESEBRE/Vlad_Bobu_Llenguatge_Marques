{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Classificació Mario Kart E-Games",
  "type": "object",
  "properties": {
    "circuit": {
      "type": "string",
      "enum": [
        "Prado Rosquilla",
        "Cataratas Yoshi",
        "Barranco Goloso",
        "Fábrica de Toad"
      ],
      "description": "Nom del circuit (Opcional)"
    },
    "Classificació": {
      "type": "array",
      "minItems": 2,
      "maxItems": 20,
      "items": {
        "type": "object",
        "properties": {
          "posició": {
            "type": "integer",
            "minimum": 1,
            "maximum": 20
          },
          "nick-player": {
            "type": "string"
          },
          "personatge": {
            "type": "string"
          },
          "color": {
            "type": "string",
            "enum": ["blanc", "negre", "groc", "blau", "roig", "verd", "taronja", "lila", "rosa"]
          },
          "Temps": {
            "type": "string",
            "pattern": "^\\d{2}:\\d{2}$"
          },
          "voltes": {
            "type": "integer",
            "minimum": 0,
            "maximum": 5
          },
          "Accidents": {
            "type": "integer"
          },
          "Nitros": {
            "type": "integer"
          },
          "Rookie": {
            "type": "string",
            "enum": ["SI", "NO", "Si", "No"]
          }
        },
        "required": [
          "posició",
          "nick-player",
          "personatge",
          "Temps",
          "voltes",
          "Accidents"
        ],
        "additionalProperties": false
      }
    }
  },
  "required": [
    "Classificació"
  ],
  "additionalProperties": false
}
